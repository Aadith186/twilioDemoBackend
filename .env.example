PORT=4000
MONGODB_URI=mongodb://localhost:27017/construction-chat
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
CLIENT_URL=http://localhost:3000

# ─── TWILIO VOICE ──────────────────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here

# Your server's public URL (Twilio needs to reach your webhooks)
# For local dev: use ngrok → ngrok http 4000 → paste the https URL here
SERVER_PUBLIC_URL=https://your-ngrok-url.ngrok-free.app

# Voice settings (optional, defaults shown)
# TWILIO_VOICE=Polly.Matthew
# TWILIO_SPEECH_LANG=en-IN
# TWILIO_SPEECH_TIMEOUT=auto
